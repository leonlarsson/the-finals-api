{
  "name": "the-finals-api",
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "deploy": "wrangler deploy --minify",
    "types": "wrangler types --env-interface CloudflareBindings",
    "biome": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "db:migration:new": "wrangler d1 migrations create the-finals-api",
    "db:migration:apply": "wrangler d1 migrations apply the-finals-api",
    "db:migration:apply:remote": "wrangler d1 migrations apply the-finals-api --remote"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.11.8",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  }
}
